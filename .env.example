# Signal FM Environment Variables
# Copy this file to .env and fill in the values

# Required
GLM_API_KEY=your_zhipuai_api_key_here

# Optional — NewsAPI for keyword-based fetching
NEWSAPI_KEY=your_newsapi_key_here

# Optional — Feishu webhook for text summary push
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/...
# Minimum score to push to Feishu (0-100)
FEISHU_MIN_SCORE=80

# Redis connection
REDIS_URL=redis://redis:6379

# Audio cache directory (inside container)
AUDIO_CACHE_DIR=/data/audio

# TTS voice selection: zh-CN-female | zh-CN-male | zh-TW-female
TTS_VOICE=zh-CN-female
